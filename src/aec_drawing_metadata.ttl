@prefix : <http://example.org/aec-drawing-ontology#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix xml: <http://www.w3.org/XML/1998/namespace#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
# Created/edited with https://alelom.github.io/OntoCanvas/ version 1.8.1

:Detail rdfs:subClassOf [ rdf:type owl:Restriction ; owl:onProperty :has ; owl:someValuesFrom :DetailLocation ].

#################################################################
#    Ontology
#################################################################

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata> rdf:type owl:Ontology;
    rdfs:label "AEC Drawing Metadata Ontology";
    rdfs:comment "Sheet/layout/document structure for AEC drawings.";
    owl:versionIRI <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata/1.0.0>;
    owl:versionInfo "1.0.0";
    owl:imports <http://www.w3.org/2002/07/owl#>, <http://www.w3.org/1999/02/22-rdf-syntax-ns#>, <http://www.w3.org/XML/1998/namespace#>, <http://www.w3.org/2001/XMLSchema#>, <http://www.w3.org/2000/01/rdf-schema#> ;
    owl:imports <http://www.w3.org/1999/02/22-rdf-syntax-ns#> ;
    owl:imports <http://www.w3.org/2000/01/rdf-schema#> ;
    owl:imports <http://www.w3.org/2001/XMLSchema#> ;
    owl:imports <http://www.w3.org/XML/1998/namespace#> ;
    owl:imports <https://burohappoldmachinelearning.github.io/ADIRO> ;
    owl:imports <https://burohappoldmachinelearning.github.io/ADIRO/aec-common-symbols#> ;
    rdfs:comment "Created/edited with https://alelom.github.io/OntoCanvas/ version 1.8.1" .


#################################################################
#    Annotation properties
#################################################################

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#exampleImage> rdf:type owl:AnnotationProperty;
    rdfs:label "example image"@en;
    rdfs:comment "Links a class or concept to an example image illustrating it."@en.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> rdf:type owl:AnnotationProperty;
    rdfs:label "Labellable root";
    rdfs:comment "When true, this class can be used as a label by annotators (solid contour in diagram). When false, non-labellable (dashed contour).";
    rdfs:range xsd:boolean.

#################################################################
#    Object Properties
#################################################################

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#contains> rdf:type owl:ObjectProperty;
    rdfs:label "contains";
    rdfs:comment "Direct containment or has-part relationship. Min cardinality 0 by default (can contain).";
    rdfs:range owl:Thing;
    rdfs:domain owl:Thing.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#has> rdf:type owl:ObjectProperty;
    rdfs:label "hasProperty";
    rdfs:comment "Subject is characterised by a property.";
    rdfs:range owl:Thing;
    rdfs:domain owl:Thing.

#################################################################
#    Data Properties
#################################################################

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#refersToDrawingId> rdf:type owl:DatatypeProperty;
    rdfs:label "refersToDrawingId";
    rdfs:comment "References another Drawing by using a drawing identifier, like a drawing number.";
    rdfs:range xsd:string;
    rdfs:domain <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#TextualNote>.

#################################################################
#    Classes
#################################################################

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#TextualNote> rdf:type owl:Class;
    rdfs:label "Text";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "true"^^xsd:boolean;
    rdfs:subClassOf <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Note>.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Note> rdf:type owl:Class;
    rdfs:label "Note";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "true"^^xsd:boolean;
    rdfs:subClassOf <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Metadata>.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Metadata> rdf:type owl:Class;
    rdfs:label "Metadata";
    rdfs:comment "Can be standalone label - drawing metadata";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "false"^^xsd:boolean.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#DrawingSheet> rdf:type owl:Class;
    rdfs:label "Drawing sheet";
    rdfs:comment "Top-level container for a drawing. Contains Layout(s).";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "false"^^xsd:boolean;
    rdfs:subClassOf [ rdf:type owl:Restriction ; owl:onProperty <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#contains> ; owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ; owl:onClass <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Note> ], [ rdf:type owl:Restriction ; owl:onProperty <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#contains> ; owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ; owl:onClass <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#RevisionTable> ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ], [ rdf:type owl:Restriction ; owl:onProperty <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#contains> ; owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Layout> ], [ rdf:type owl:Restriction ; owl:onProperty <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#has> ; owl:onClass <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#DrawingOrientation> ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ].

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#RevisionTable> rdf:type owl:Class;
    rdfs:label "Revision table";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "true"^^xsd:boolean;
    rdfs:subClassOf <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Metadata>.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Layout> rdf:type owl:Class;
    rdfs:label "Layout";
    rdfs:comment "Drawing layout - contained by DrawingSheet. Contains DrawingElement(s), annotations, drawing type, and content.";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "true"^^xsd:boolean;
    rdfs:subClassOf [ rdf:type owl:Restriction ; owl:onProperty <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#contains> ; owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ; owl:onClass <https://burohappoldmachinelearning.github.io/ADIRO/aec-common-symbols#DrawingElement> ], [ rdf:type owl:Restriction ; owl:onProperty <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#has> ; owl:onClass <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#DrawingType> ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ].

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#DrawingOrientation> rdf:type owl:Class;
    rdfs:label "DrawingOrientation";
    rdfs:subClassOf <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Portrait>, <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Landscape>.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#DrawingType> rdf:type owl:Class;
    rdfs:label "Drawing type";
    rdfs:comment "Type of drawing view";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "false"^^xsd:boolean.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Portrait> rdf:type owl:Class;
    rdfs:label "Portrait";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "true"^^xsd:boolean.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Landscape> rdf:type owl:Class;
    rdfs:label "Landscape";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "true"^^xsd:boolean.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Titleblock> rdf:type owl:Class;
    rdfs:label "Titleblock";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "true"^^xsd:boolean;
    rdfs:subClassOf <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Metadata>.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Legend> rdf:type owl:Class;
    rdfs:label "Legend";
    rdfs:comment "A legend containing mapping information between symbols and a text signifier.";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "true"^^xsd:boolean;
    rdfs:subClassOf <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Metadata>.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Image> rdf:type owl:Class;
    rdfs:label "Image";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "true"^^xsd:boolean;
    rdfs:subClassOf <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Note>.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Plan> rdf:type owl:Class;
    rdfs:label "Plan";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "true"^^xsd:boolean;
    rdfs:subClassOf <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#DrawingType>.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Section> rdf:type owl:Class;
    rdfs:label "Vertical Section";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "true"^^xsd:boolean;
    rdfs:subClassOf <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#DrawingType>.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Elevation> rdf:type owl:Class;
    rdfs:label "Elevation";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "true"^^xsd:boolean;
    rdfs:subClassOf <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#DrawingType>.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Detail> rdf:type owl:Class;
    rdfs:label "Detail";
    rdfs:comment "Detail drawing";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "true"^^xsd:boolean;
    rdfs:subClassOf <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#DrawingType>, [ rdf:type owl:Restriction ; owl:onProperty <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#has> ; owl:onClass <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Orientation> ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ].

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Orientation> rdf:type owl:Class;
    rdfs:label "Detail Orientation";
    rdfs:comment "Can be standalone label - drawing orientation";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "false"^^xsd:boolean.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Perspective> rdf:type owl:Class;
    rdfs:label "Perspective";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "true"^^xsd:boolean;
    rdfs:subClassOf <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#DrawingType>.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#DetailLocation> rdf:type owl:Class;
    rdfs:label "Detail location";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "false"^^xsd:boolean.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Base> rdf:type owl:Class;
    rdfs:label "Base";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "false"^^xsd:boolean;
    rdfs:subClassOf <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#DetailLocation>.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Corner> rdf:type owl:Class;
    rdfs:label "Corner";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "false"^^xsd:boolean;
    rdfs:subClassOf <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#DetailLocation>.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Head> rdf:type owl:Class;
    rdfs:label "Head";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "false"^^xsd:boolean;
    rdfs:subClassOf <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#DetailLocation>.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#SlabEdge> rdf:type owl:Class;
    rdfs:label "Slab edge";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "false"^^xsd:boolean;
    rdfs:subClassOf <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#DetailLocation>.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Typical> rdf:type owl:Class;
    rdfs:label "Typical";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "false"^^xsd:boolean;
    rdfs:subClassOf <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#DetailLocation>.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Horizontal> rdf:type owl:Class;
    rdfs:label "Horizontal";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "true"^^xsd:boolean;
    rdfs:subClassOf <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Orientation>.

<https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#Vertical> rdf:type owl:Class;
    rdfs:label "Vertical";
    <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#labellableRoot> "true"^^xsd:boolean;
