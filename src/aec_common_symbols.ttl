@prefix : <https://burohappoldmachinelearning.github.io/ADIRO/aec-common-symbols#> .
@prefix metadata: <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://burohappoldmachinelearning.github.io/ADIRO/aec-common-symbols> rdf:type owl:Ontology ;
    rdfs:label "AEC Common Symbols Ontology" ;
    rdfs:comment "Cross-discipline layout content. Generic symbol classes like dimensions, callouts, grids, etc. (mostly reusable non-domain symbols). All symbols are subclasses of DrawingElement from the drawing metadata ontology." ;
    owl:versionIRI <https://burohappoldmachinelearning.github.io/ADIRO/aec-common-symbols/1.0.0> ;
    owl:versionInfo "1.0.0" ;
    owl:imports <https://burohappoldmachinelearning.github.io/ADIRO/aec-drawing-metadata> .

#################################################################
#    Classes
#################################################################

:Dimension rdf:type owl:Class;
    rdfs:subClassOf metadata:DrawingElement;
    rdfs:label "Dimension";
    rdfs:comment "A dimension line or dimension annotation on a drawing, indicating measurements or distances.";
    metadata:labellableRoot "true"^^xsd:boolean.

:Callout rdf:type owl:Class;
    rdfs:subClassOf metadata:DrawingElement;
    rdfs:label "Callout";
    rdfs:comment "A callout or detail marker that references another part of the drawing or a detail view.";
    metadata:labellableRoot "true"^^xsd:boolean.

:Grid rdf:type owl:Class;
    rdfs:subClassOf metadata:DrawingElement;
    rdfs:label "Grid";
    rdfs:comment "A grid line or grid system used for alignment and reference in architectural drawings.";
    metadata:labellableRoot "true"^^xsd:boolean.
