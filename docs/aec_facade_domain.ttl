    rdfs:subClassOf :Membrane.

:Blockwork rdf:type owl:Class;
    rdfs:label "Blockwork";
    metadata:labellableRoot "false"^^xsd:boolean;
    rdfs:subClassOf :RoofCladding.

:TimberCassette rdf:type owl:Class;
    rdfs:label "Timber cassette";
    metadata:labellableRoot "false"^^xsd:boolean;
    rdfs:subClassOf :RoofCladding.

:SFS rdf:type owl:Class;
    rdfs:label "SFS";
    rdfs:comment "Steel Frame System";
    metadata:labellableRoot "false"^^xsd:boolean;
    rdfs:subClassOf :BackingWall.

:DeadLoadBracket rdf:type owl:Class;
    rdfs:label "Dead load";
    rdfs:comment "Dead load bracket";
    metadata:labellableRoot "false"^^xsd:boolean;
    rdfs:subClassOf :Bracket.

:HelpingHandBracket rdf:type owl:Class;
    rdfs:label "Helping hand";
    rdfs:comment "Helping hand bracket";
    metadata:labellableRoot "false"^^xsd:boolean;
    rdfs:subClassOf :Bracket.

:PrecastRestraintBracket rdf:type owl:Class;
    rdfs:label "Precast restraint";
    rdfs:comment "Precast restraint bracket";
    metadata:labellableRoot "false"^^xsd:boolean;
