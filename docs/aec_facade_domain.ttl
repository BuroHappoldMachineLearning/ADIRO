    metadata:labellableRoot "false"^^xsd:boolean;
    rdfs:subClassOf :Board.

:Plasterboard rdf:type owl:Class;
    rdfs:label "Plasterboard";
    metadata:labellableRoot "false"^^xsd:boolean;
