@prefix : <https://burohappoldmachinelearning.github.io/ADIRO/aec_domain_common#> .
@prefix metadata: <https://burohappoldmachinelearning.github.io/ADIRO/aec_drawing_metadata#> .
@prefix common: <https://burohappoldmachinelearning.github.io/ADIRO/aec_common_symbols#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://burohappoldmachinelearning.github.io/ADIRO/aec_domain_common> rdf:type owl:Ontology ;
    rdfs:label "AEC Domain Common Ontology" ;
    rdfs:comment "Shared domain abstractions reused across multiple domain ontologies (e.g., facade+structural)." ;
    owl:versionIRI <https://burohappoldmachinelearning.github.io/ADIRO/aec_domain_common/1.0.0> ;
    owl:versionInfo "1.0.0" ;
    owl:imports <https://burohappoldmachinelearning.github.io/ADIRO/aec_drawing_metadata>,
                <https://burohappoldmachinelearning.github.io/ADIRO/aec_common_symbols> .

#################################################################
#    Property Classes
#################################################################

:MaterialProperties rdf:type owl:Class ;
    rdfs:comment "General property category" ;
    rdfs:label "Material properties" ;
    metadata:labellableRoot "false"^^xsd:boolean .

:Material rdf:type owl:Class ;
    rdfs:label "Material" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :MaterialProperties .

:FunctionalProperties rdf:type owl:Class ;
    rdfs:comment "General property category" ;
    rdfs:label "Functional properties" ;
    metadata:labellableRoot "false"^^xsd:boolean .

:Function rdf:type owl:Class ;
    rdfs:label "Function" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :FunctionalProperties .

:GeometricProperties rdf:type owl:Class ;
    rdfs:comment "General property category" ;
    rdfs:label "Geometric properties" ;
    metadata:labellableRoot "false"^^xsd:boolean .

:SectionProperties rdf:type owl:Class ;
    rdfs:comment "General property category" ;
    rdfs:label "Section properties" ;
    metadata:labellableRoot "false"^^xsd:boolean .

:StructuralProperties rdf:type owl:Class ;
    rdfs:comment "General property category" ;
    rdfs:label "Structural properties" ;
    metadata:labellableRoot "false"^^xsd:boolean .

#################################################################
#    Material Subclasses
#################################################################

:Aluminium rdf:type owl:Class ;
    rdfs:label "Aluminium" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :Material .

:Concrete rdf:type owl:Class ;
    rdfs:label "Concrete" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :Material .

:Glass rdf:type owl:Class ;
    rdfs:label "Glass" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :Material .

:Metal rdf:type owl:Class ;
    rdfs:label "Metal" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :Material .

:Timber rdf:type owl:Class ;
    rdfs:label "Timber" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :Material .

:Polycarbonate rdf:type owl:Class ;
    rdfs:label "Polycarbonate" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :Material .

:Precast rdf:type owl:Class ;
    rdfs:label "Precast" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :Material .

:Clay rdf:type owl:Class ;
    rdfs:label "Clay" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :Material .

#################################################################
#    Facing Material
#################################################################

:FacingMaterial rdf:type owl:Class ;
    rdfs:comment "Can be standalone label - material used for facing" ;
    rdfs:label "Facing material" ;
    metadata:labellableRoot "false"^^xsd:boolean .

:Brick rdf:type owl:Class ;
    rdfs:label "Brick" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :FacingMaterial .

:Stone rdf:type owl:Class ;
    rdfs:label "Stone" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :FacingMaterial .

:Terracotta rdf:type owl:Class ;
    rdfs:label "Terracotta" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :FacingMaterial .

#################################################################
#    Section/Shape Properties
#################################################################

:SectionShape rdf:type owl:Class ;
    rdfs:label "Section shape" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :SectionProperties .

:GenericShapeProperty rdf:type owl:Class ;
    rdfs:label "Generic shape property" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :SectionProperties .

:Symmetry rdf:type owl:Class ;
    rdfs:label "Symmetry" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :SectionProperties .

:CHS rdf:type owl:Class ;
    rdfs:label "CHS" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :SectionShape .

:ISection rdf:type owl:Class ;
    rdfs:label "I-section" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :SectionShape .

:RHS rdf:type owl:Class ;
    rdfs:label "RHS" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :SectionShape .

:SectionChannel rdf:type owl:Class ;
    rdfs:label "Channel (section)" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :SectionShape .

:TopHat rdf:type owl:Class ;
    rdfs:label "Top hat" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :SectionShape .

:Circular rdf:type owl:Class ;
    rdfs:label "Circular" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :GenericShapeProperty .

:Rectangular rdf:type owl:Class ;
    rdfs:label "Rectangular" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :GenericShapeProperty .

:Square rdf:type owl:Class ;
    rdfs:label "Square" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :GenericShapeProperty .

:Asymmetrical rdf:type owl:Class ;
    rdfs:label "Asymmetrical" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :Symmetry .

:Symmetrical rdf:type owl:Class ;
    rdfs:label "Symmetrical" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :Symmetry .

#################################################################
#    Structural Properties
#################################################################

:DeadLoad rdf:type owl:Class ;
    rdfs:label "Dead load" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :StructuralProperties .

:Restraint rdf:type owl:Class ;
    rdfs:label "Restraint" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :StructuralProperties .

#################################################################
#    Structural Components
#################################################################

:StructuralComponent rdf:type owl:Class ;
    rdfs:comment "Structural component - part of support type" ;
    rdfs:label "Structural component" ;
    metadata:labellableRoot "false"^^xsd:boolean .

:LinearStructuralComponent rdf:type owl:Class ;
    rdfs:label "Linear structural component" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :StructuralComponent .

:PanelStructuralComponent rdf:type owl:Class ;
    rdfs:label "Panel structural component" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :StructuralComponent .

:StructuralMember rdf:type owl:Class ;
    rdfs:label "Structural member" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :LinearStructuralComponent .

:Beam rdf:type owl:Class ;
    rdfs:label "Beam" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :StructuralMember .

:Column rdf:type owl:Class ;
    rdfs:label "Column" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :StructuralMember .

:ChordBracing rdf:type owl:Class ;
    rdfs:label "Chord/bracing" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :StructuralMember .

:Cable rdf:type owl:Class ;
    rdfs:label "Cable" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :LinearStructuralComponent .

:Slab rdf:type owl:Class ;
    rdfs:label "Slab" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :PanelStructuralComponent .

:Wall rdf:type owl:Class ;
    rdfs:label "Wall" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :PanelStructuralComponent .

:Upstand rdf:type owl:Class ;
    rdfs:label "Upstand" ;
    metadata:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :PanelStructuralComponent .
