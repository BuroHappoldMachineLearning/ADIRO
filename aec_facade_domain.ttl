#################################################################
#    Ontology
#################################################################

<http://example.org/aec-drawing/v01/facade-domain> rdf:type owl:Ontology;
    rdfs:label "AEC Facade Domain Ontology";
    rdfs:comment "Facade-specific concepts and symbols for facade engineering drawings.";
    owl:imports <http://example.org/aec-drawing/v01/core>, <http://example.org/aec-drawing/v01/drawing-metadata>, <http://example.org/aec-drawing/v01/common-symbols>, <http://example.org/aec-drawing/v01/domain-common> ;
    owl:imports <http://example.org/aec-drawing/v01> ;
    owl:imports <http://example.org/aec-drawing/v01/common-symbols> ;
    owl:imports <http://example.org/aec-drawing/v01/domain-common> ;
    owl:imports <http://example.org/aec-drawing/v01/drawing-metadata> ;
    owl:imports <http://www.w3.org/1999/02/22-rdf-syntax-ns#> ;
    owl:imports <http://www.w3.org/2000/01/rdf-schema#> ;
    owl:imports <http://www.w3.org/2001/XMLSchema#> ;
    owl:imports <http://www.w3.org/2002/07/owl#> ;
    owl:imports <http://www.w3.org/XML/1998/namespace#> ;
    rdfs:comment "Created/edited with https://alelom.github.io/OntoCanvas/ version 1.6.0" .


#################################################################
#    Annotation properties
#################################################################

<http://example.org/aec-drawing/v01/facade-domain#exampleImage> rdf:type owl:AnnotationProperty;
    rdfs:label "example image"@en;
    rdfs:comment "Links a class or concept to an example image illustrating it."@en.

#################################################################
#    Classes
#################################################################

<http://example.org/aec-drawing/v01/facade-domain#FacadeComponent> rdf:type owl:Class;
    rdfs:label "Facade component";
    rdfs:comment "Component of a facade system; a type of drawing element";
    <http://example.org/aec-drawing/v01/core#labellableRoot> "false"^^xsd:boolean;
    rdfs:subClassOf <http://example.org/aec-drawing/v01/common-symbols#DrawingElement>.

<http://example.org/aec-drawing/v01/facade-domain#FacadeSystem> rdf:type owl:Class;
    rdfs:label "Facade system";
    rdfs:comment "Facade system - part of support type; a type of drawing element";
    <http://example.org/aec-drawing/v01/core#labellableRoot> "false"^^xsd:boolean;
    rdfs:subClassOf <http://example.org/aec-drawing/v01/common-symbols#DrawingElement>, [ rdf:type owl:Restriction ; owl:onProperty <http://example.org/aec-drawing/v01/core#contains> ; owl:someValuesFrom <http://example.org/aec-drawing/v01/facade-domain#FacadeComponent> ].

<http://example.org/aec-drawing/v01/facade-domain#LinearComponent> rdf:type owl:Class;
