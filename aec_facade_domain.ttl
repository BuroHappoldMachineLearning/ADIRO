@prefix : <http://example.org/aec-drawing/v01/facade-domain#> .
@prefix core: <http://example.org/aec-drawing/v01/core#> .
@prefix metadata: <http://example.org/aec-drawing/v01/drawing-metadata#> .
@prefix common: <http://example.org/aec-drawing/v01/common-symbols#> .
@prefix dcommon: <http://example.org/aec-drawing/v01/domain-common#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/aec-drawing/v01/facade-domain> rdf:type owl:Ontology ;
    rdfs:label "AEC Facade Domain Ontology" ;
    rdfs:comment "Facade-specific concepts and symbols for facade engineering drawings." ;
    owl:imports <http://example.org/aec-drawing/v01/core>,
                <http://example.org/aec-drawing/v01/drawing-metadata>,
                <http://example.org/aec-drawing/v01/common-symbols>,
                <http://example.org/aec-drawing/v01/domain-common> .

#################################################################
#    Facade Drawing Elements
#################################################################

:FacadeComponent rdf:type owl:Class ;
    rdfs:comment "Component of a facade system; a type of drawing element" ;
    rdfs:label "Facade component" ;
    core:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf common:DrawingElement .

:FacadeSystem rdf:type owl:Class ;
    rdfs:comment "Facade system - part of support type; a type of drawing element" ;
    rdfs:label "Facade system" ;
    core:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf common:DrawingElement,
        [ rdf:type owl:Restriction ; owl:onProperty core:contains ; owl:someValuesFrom :FacadeComponent ] .

#################################################################
#    Facade Component Categories
#################################################################

:LinearComponent rdf:type owl:Class ;
    rdfs:comment "Element category - linear facade component" ;
    rdfs:label "Linear component" ;
    core:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :FacadeComponent .

:PanelComponent rdf:type owl:Class ;
    rdfs:comment "Element category - panel-type facade component" ;
    rdfs:label "Panel component" ;
    core:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :FacadeComponent .

:PointComponent rdf:type owl:Class ;
    rdfs:comment "Element category - point-type facade component" ;
    rdfs:label "Point component" ;
    core:labellableRoot "false"^^xsd:boolean ;
    rdfs:subClassOf :FacadeComponent .

